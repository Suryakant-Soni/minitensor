Broadcast preparation
function prepare_for_broadcast(tensor, result_shape):
    aligned_shape   = left_pad_with_ones(tensor.shape, len(result_shape))
    aligned_strides = left_pad_with_zeros_or_dummy(tensor.strides, len(result_shape))

    new_strides = array of length len(result_shape)

    for dim in 0 .. rank-1:
        if aligned_shape[dim] == result_shape[dim]:
            new_strides[dim] = aligned_strides[dim]
        else if aligned_shape[dim] == 1:
            new_strides[dim] = 0
        else:
            error "not broadcastable"

    return PreparedTensor(
        storage = tensor.storage,
        shape   = result_shape,
        strides = new_strides,
        offset  = tensor.offset
    )
Flat index from metadata
function compute_flat_index_from_parts(idx, shape, strides, offset):
    flat = offset

    for dim in 0 .. len(shape)-1:
        flat += idx[dim] * strides[dim]

    return flat

