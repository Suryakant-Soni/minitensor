Advance both logical index and flat positions
function advance_index_and_flats(idx, shape, a_strides, b_strides, a_flat, b_flat):
    for dim in reverse(rank-1 .. 0):
        idx[dim] += 1
        a_flat += a_strides[dim]
        b_flat += b_strides[dim]

        if idx[dim] < shape[dim]:
            return

        idx[dim] = 0

        a_flat -= shape[dim] * a_strides[dim]
        b_flat -= shape[dim] * b_strides[dim]

