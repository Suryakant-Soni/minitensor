    prepared_b = prepare_for_broadcast(b, result_shape)

    out = zeros(result_shape)
    out_buf = out.mutable_contiguous_buffer()

    idx = [0] * rank(result_shape)

    for out_i in 0 .. numel(result_shape):
        a_flat = prepared_a.offset
        b_flat = prepared_b.offset

        for d in 0 .. rank(result_shape)-1:
            a_flat += idx[d] * prepared_a.strides[d]
            b_flat += idx[d] * prepared_b.strides[d]

        out_buf[out_i] = f(
            prepared_a.storage[a_flat],
            prepared_b.storage[b_flat]
        )

        increment_nd_index(idx, result_shape)

    return out

