Kernel pseudo code
function binary_op(a, b, f):
    result_shape = compute_broadcast_shape(a.shape, b.shape)

    prepared_a = prepare_for_broadcast(a, result_shape)
    prepared_b = prepare_for_broadcast(b, result_shape)

    out = zeros(result_shape)
    out_buf = out.mutable_contiguous_buffer()

    total = numel(result_shape)
    rank = len(result_shape)

    idx = [0, 0, ..., 0]   // length = rank

    for flat_out in 0 .. total:
        a_flat = prepared_a.offset
        b_flat = prepared_b.offset

        for dim in 0 .. rank-1:
            a_flat += idx[dim] * prepared_a.strides[dim]
            b_flat += idx[dim] * prepared_b.strides[dim]

        av = prepared_a.storage[a_flat]
        bv = prepared_b.storage[b_flat]

        out_buf[flat_out] = f(av, bv)

        increment_nd_index(idx, result_shape)

    return out
Increment logical index like an odometer
function increment_nd_index(idx, shape):
    for dim in reverse(rank-1 .. 0):
        idx[dim] += 1

        if idx[dim] < shape[dim]:
            return

        idx[dim] = 0

